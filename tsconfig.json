{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "app/(auth)/login/page.jsx", "app/(main)/about/page.jsx", "app/(auth)/signup/page.jsx", "app/(main)/blog/page.jsx", "app/(main)/faqs/page.jsx", "app/(main)/dashboard/purchasing/page.jsx", "app/(main)/dashboard/favourites/page.jsx", "app/(main)/dashboard/chat/page.jsx", "app/(main)/page.jsx", "app/(main)/products/[id]/page.jsx", "components/ProductGrid.jsx", "components/Footer.jsx", "components/Navbar.jsx", "app/layout.jsx"  ],
  "exclude": ["node_modules"]
}
